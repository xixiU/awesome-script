# 验证码识别服务配置文件
# Captcha Recognition Service Configuration

# 服务配置
HOST=0.0.0.0
PORT=9876
WORKERS=4
TIMEOUT=120
MAX_REQUESTS=1000
MAX_REQUESTS_JITTER=100

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=/root/mySource/ocr_dddd/logs/captcha_service.log
ACCESS_LOG_FILE=/root/mySource/ocr_dddd/logs/access.log
ERROR_LOG_FILE=/root/mySource/ocr_dddd/logs/error.log

# 性能配置
KEEPALIVE=2
MAX_REQUESTS_PER_WORKER=1000
PRELOAD_APP=true

# 安全配置
FORWARDED_ALLOW_IPS=*
